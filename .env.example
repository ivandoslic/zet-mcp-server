# Interval osvježavanja GTFS-RT podataka (u sekundama)
GTFS_RT_REFRESH_INTERVAL=30

# Interval ponovnog preuzimanja statičkog GTFS-a (u satima)
GTFS_STATIC_REFRESH_HOURS=24

# ZET GTFS URL-ovi (popunit ćemo kad provjerimo službene)
GTFS_STATIC_URL=https://www.zet.hr/gtfs-static.zip
GTFS_RT_TRIPS_URL=https://www.zet.hr/gtfs-rt/tripUpdates
GTFS_RT_VEHICLES_URL=https://www.zet.hr/gtfs-rt/vehiclePositions

# MCP server port
MCP_PORT=8000